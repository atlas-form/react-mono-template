# Put this file OUTSIDE the repo, for example:
# ~/.config/frontend-env/.env.development
# ~/.config/frontend-env/.env.production

# Runtime API bases used by apps
VITE_WEB_API_URL=/api
VITE_ADMIN_API_URL=/api
VITE_AUTH_URL=/auth
VITE_FILE_URL=/file

# Dev proxy targets
VITE_WEB_API_PROXY=http://localhost:8000
VITE_ADMIN_API_PROXY=http://localhost:8001
VITE_AUTH_PROXY=http://localhost:9000
VITE_FILE_PROXY=http://localhost:9000

{
  "name": "vite-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "node scripts/clean.mjs",
    "dev": "node scripts/dev.mjs",
    "mock": "node scripts/mock.mjs",
    "preview": "pnpm -C apps/web preview",
    "dev:all": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test --filter=admin --filter=guide --filter=web",
    "test:rules": "pnpm -C packages/ui-components test:rules && pnpm -C packages/app-components test:rules",
    "test:watch": "turbo test:watch --filter=admin --filter=guide --filter=web"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}

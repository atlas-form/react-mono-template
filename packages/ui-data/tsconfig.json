{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@workspace/app-components": ["../app-components/src/index.ts"],
      "@workspace/app-components/*": ["../app-components/src/*"],
      "@workspace/ui-components": ["../ui-components/src/index.ts"],
      "@workspace/ui-components/*": ["../ui-components/src/*"],
      "@workspace/ui-data/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
